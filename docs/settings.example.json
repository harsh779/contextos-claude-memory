{
  "_comment": "Example Claude Code settings for ContextOS. Replace <User> with your Windows username, or use the path printed by install.ps1.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\<User>\\AI-Memory-Vault\\scripts\\contextos-start.ps1\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\<User>\\AI-Memory-Vault\\scripts\\contextos-capture.ps1\"",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "permissions": {
    "_comment": "These permissions allow ContextOS to read/write only inside the local memory vault and run its own hook scripts.",
    "allow": [
      "Read(C:\\Users\\<User>\\AI-Memory-Vault\\**)",
      "Write(C:\\Users\\<User>\\AI-Memory-Vault\\**)",
      "Edit(C:\\Users\\<User>\\AI-Memory-Vault\\**)",
      "Bash(powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\<User>\\AI-Memory-Vault\\scripts\\contextos-start.ps1\")",
      "Bash(powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\<User>\\AI-Memory-Vault\\scripts\\contextos-capture.ps1\")",
      "Bash(python \"C:\\Users\\<User>\\AI-Memory-Vault\\scripts\\process-session.py\"*)"
    ]
  }
}